// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      String   @default("CUSTOMER") // CUSTOMER | ADMIN
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  description String
  price       Float
  category    String      // BRACELETS | EARRINGS | RINGS
  images      String      @default("[]") // JSON array of image paths
  stock       Int         @default(0)
  featured    Boolean     @default(false)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNumber   String      @unique
  userId        Int?
  user          User?       @relation(fields: [userId], references: [id])
  name          String
  phone         String
  address       String
  city          String
  notes         String?
  status        String      @default("PENDING") // PENDING | PROCESSING | SHIPPED | DELIVERED | CANCELLED
  items         OrderItem[]
  subtotal      Float
  deliveryFee   Float
  discount      Float       @default(0)
  total         Float
  paymentMethod String      @default("cod") // cod | online
  transactionId String?
  couponCode    String?
  paidDelivery  Boolean     @default(false)
  discountBreakdown String  @default("{}") // JSON breakdown of applied discounts
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Coupon {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  discount   Float     // percentage e.g. 10 = 10%
  usageLimit Int?
  usageCount Int       @default(0)
  expiresAt  DateTime?
  active     Boolean   @default(true)
  totalRevenue Float   @default(0) // total order value from this coupon
  totalSaved   Float   @default(0) // total discount given
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Settings {
  id          Int    @id @default(1)
  bkashNumber String @default("")
  bankName    String @default("")
  bankAccount String @default("")
  bankBranch  String @default("")
  bankHolder  String @default("")
  deliveryFee Float  @default(80)
  bannerText  String @default("")
  bannerActive Boolean @default(false)
  storeName   String @default("Laay")
  storeEmail  String @default("")
  storePhone  String @default("")
}
